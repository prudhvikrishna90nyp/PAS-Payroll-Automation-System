# =============================================================================
# PAS environment template — copy to `.env` and edit. NEVER commit real secrets.
# =============================================================================

# Django
SECRET_KEY=change-me-to-a-long-random-value
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Production example:
# DEBUG=False
# ALLOWED_HOSTS=payroll.example.com,www.payroll.example.com

# Settings module (optional; manage.py defaults to development, Docker/gunicorn use production)
# DJANGO_SETTINGS_MODULE=config.settings.production

# -----------------------------------------------------------------------------
# Database
# Leave DB_NAME empty to use SQLite (local development only).
# Set DB_NAME to enable PostgreSQL (required for production payroll).
# PAS reads DB_* only — it does not parse DATABASE_URL. Map URL parts to DB_*.
# Docker Compose Postgres image uses POSTGRES_* for the container; Django still
# needs matching DB_NAME / DB_USER / DB_PASSWORD (Compose sets these on `web`).
# -----------------------------------------------------------------------------
# DB_NAME=payroll
# DB_USER=postgres
# DB_PASSWORD=change-me
# DB_HOST=localhost
# DB_PORT=5432
#
# Example mapping from DATABASE_URL=postgresql://USER:PASS@HOST:5432/NAME :
#   DB_USER=USER  DB_PASSWORD=PASS  DB_HOST=HOST  DB_PORT=5432  DB_NAME=NAME
#
# Compose db service (reference — set in docker-compose, not required in .env):
#   POSTGRES_DB=payroll
#   POSTGRES_USER=postgres
#   POSTGRES_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Production HTTPS / CSRF (required behind a real domain)
# -----------------------------------------------------------------------------
# SECURE_SSL_REDIRECT=True
# CSRF_TRUSTED_ORIGINS=https://payroll.example.com

# -----------------------------------------------------------------------------
# Optional: non-interactive admin for Docker / first boot
#   python manage.py ensure_admin
# -----------------------------------------------------------------------------
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=change-me-strong-password

# -----------------------------------------------------------------------------
# Email stubs (optional — configure before employee payslip email features)
# -----------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=payroll@example.com
